@{
    ViewData["Title"] = "Home";
}

<section class="top">
    @await Html.PartialAsync("_Navbar")
    <h1 class="title">Welcome to the E-Sports League Community</h1>
    <p class="text">Join the action, follow your favorite teams...</p>
</section>

<section class="mid">
    <div class="description">
        <div class="mission">
            <h1 class="title">Our Mission</h1>
            <p class="text">We aim to create a competitive...</p>
            <button class="button">Read more</button>
        </div>
        <div class="objectives">
            <h1 class="title">Objectives</h1>
            <p class="text">To host world-class tournaments...</p>
            <button class="button">Read more</button>
        </div>
    </div>

    <div class="partners">
        <h1 class="title">Official Partners</h1>
        <p class="text1">Thanks to our amazing brands...</p>
        <div class="pictures">
            <img src="~/images/partner1.webp" class="partner1" />
            <img src="~/images/partner2.webp" class="partner2" />
        </div>
        <p class="text2">Our partners help us connect...</p>
    </div>
</section>

<section class="bot">
    <h1 class="title">Upcoming Matches</h1>
    <p class="text">Don't miss the next battles!</p>
    <div class="matches">
        <p class="match">Team Alpha vs Shadow Clan - March 15, 2025</p>
        <p class="match">Cyber Warriors vs Pixel Raiders - March 20, 2025</p>
        <p class="match">Dragon Fire vs Nova Legends - March 28, 2025</p>
    </div>
</section>
