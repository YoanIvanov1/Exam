@model IEnumerable<Exam.Models.Match>

@{
    ViewData["Title"] = "Home";
}

<section class="top">
    @await Html.PartialAsync("_Navbar")
    <h1 class="title">Welcome to the E-Sports League Community</h1>
    <p class="text">Join the action, follow your favorite teams, and be part of a global gaming movement. Our league    brings together passionate players and fans to celebrate competitive gaming at its best.</p>
</section>

    <div class="hero-content">
        <h1 class="title">Welcome to the League</h1>
        <p class="text">
            Follow the action, support your favorite teams, and experience competitive gaming like never before.
            Join our community and be part of the next generation of esports.
        </p>
    </div>
</section>

<section class="bot">
    <h1 class="title">Upcoming Matches</h1>
    <p class="text">Stay tuned for the next big clashes!</p>

    <div class="matches">
        @foreach (var match in Model)
        {
            <div class="match">
                <span class="match-left">@match.TeamA vs @match.TeamB</span>
                <span class="match-right">@match.Date.ToString("MMMM dd, yyyy")</span>
            </div>
        }
    </div>
</section>
