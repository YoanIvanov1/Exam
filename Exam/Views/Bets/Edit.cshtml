@model Bet

<div class="bet-crud-wrapper">
    <h2 class="bet-crud-title">Edit Bet</h2>

    <form asp-action="Edit" method="post" class="bet-crud-form">
        <input type="hidden" asp-for="Id" />

        <label>Team</label>
        <select asp-for="Team">
            <option value="@ViewBag.TeamA">@ViewBag.TeamA</option>
            <option value="@ViewBag.TeamB">@ViewBag.TeamB</option>
        </select>

        <label>Amount</label>
        <input asp-for="Amount" />

        <div class="bet-crud-actions">
            <button type="submit" class="bet-btn-save">Save</button>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="bet-btn-delete">Delete</a>
        </div>
    </form>
</div>
